{
  "name": "@ikaru5/heimdall-contract",
  "version": "0.8.0",
  "description": "Validation and Representer Objects in your Frontend",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ikaru5/heimdall-contract.git"
  },
  "type": "module",
  "main": "index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js"
    },
    "./types": {
      "types": "./types.d.ts",
      "import": "./types.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "index.js",
    "validation-base.js",
    "validations.js",
    "schema-lint.js",
    "types.js",
    "*.d.ts",
    "doc",
    "coverage-badge.svg"
  ],
  "keywords": [
    "heimdall",
    "contract",
    "validation",
    "representer"
  ],
  "devDependencies": {
    "@jest/globals": "^30.1.2",
    "jest": "^30.1.3",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "test": "node --experimental-vm-modules --no-warnings node_modules/.bin/jest --coverage",
    "build:types": "rm -f index.d.ts validation-base.d.ts validations.d.ts schema-lint.d.ts && tsc -p tsconfig.types.json",
    "test:types": "tsc -p tsconfig.typetest.json",
    "prepublishOnly": "npm test && npm run build:types && npm run test:types"
  }
}
